---
import BaseLayout from "./BaseLayout.astro";
import { site, t } from "@/data/site";
import type { Lang } from "@/data/site";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  lang: Lang;
  translationSlug?: string;
}

const { title, description, pubDate, tags, lang, translationSlug } = Astro.props;
const trans = t(lang);
const otherLang = lang === "pt" ? "en" : "pt";
const htmlLang = lang === "pt" ? "pt-BR" : "en";

const switchPath = translationSlug
  ? `/${otherLang}/blog/${translationSlug}`
  : `/${otherLang}/blog`;

const canonicalURL = new URL(Astro.url.pathname, site.url).toString();

const locale = lang === "pt" ? "pt-BR" : "en-US";
const day = pubDate.getUTCDate().toString().padStart(2, "0");
const month = pubDate
  .toLocaleDateString(locale, { month: "short", timeZone: "UTC" })
  .toUpperCase()
  .replace(".", "");
const year = pubDate.getUTCFullYear();
const formattedDate = `${day} ${month} ${year}`;

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  url: canonicalURL,
  inLanguage: htmlLang,
  author: {
    "@type": "Person",
    "@id": `${site.url}/#person`,
    name: site.fullName,
    url: site.url,
  },
  publisher: {
    "@type": "Person",
    "@id": `${site.url}/#person`,
  },
  ...(tags.length > 0 && { keywords: tags.join(", ") }),
};
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  type="article"
  switchPath={switchPath}
  canonicalURL={canonicalURL}
>
  <!-- Article-specific head tags injected into BaseLayout's <slot name="head"> -->
  <Fragment slot="head">
    <!-- OG article tags -->
    <meta property="article:published_time" content={pubDate.toISOString()} />
    <meta property="article:author" content={site.fullName} />
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- BlogPosting structured data -->
    <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(blogPostingSchema)}</script>`} />
  </Fragment>

  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-10 sm:py-14">

    <div class="mb-10" style="border-bottom: 1px solid var(--color-border-lo); padding-bottom: 1rem;">
      <a
        href={`/${lang}/blog`}
        class="text-xs font-mono opacity-50 hover:opacity-100"
        style="color: var(--color-fg);"
      >
        {trans.postBack}
      </a>
    </div>

    <article>
      <header class="mb-10">
        <h1
          class="text-2xl sm:text-3xl font-bold leading-tight mb-5"
          style="color: var(--color-fg);"
        >
          {title}
        </h1>
        <div class="flex flex-wrap items-center gap-3">
          <time
            datetime={pubDate.toISOString()}
            class="font-mono text-xs"
            style="color: var(--color-muted);"
          >
            {formattedDate}
          </time>
          {tags.map((tag) => (
            <span
              class="font-mono text-xs px-1.5 py-0.5"
              style="color: var(--color-muted); border: 1px solid var(--color-border-lo);"
            >
              #{tag}
            </span>
          ))}
        </div>
      </header>

      <div
        class="prose prose-sm sm:prose-base max-w-none
               dark:prose-invert
               prose-headings:font-semibold
               prose-p:leading-relaxed
               prose-a:underline prose-a:underline-offset-2
               prose-code:font-mono prose-code:text-sm
               prose-pre:border
               prose-blockquote:not-italic"
        style="
          --tw-prose-body: var(--color-fg);
          --tw-prose-headings: var(--color-fg);
          --tw-prose-links: var(--color-fg);
          --tw-prose-bold: var(--color-fg);
          --tw-prose-counters: var(--color-muted);
          --tw-prose-bullets: var(--color-muted);
          --tw-prose-hr: var(--color-border-lo);
          --tw-prose-quotes: var(--color-fg);
          --tw-prose-quote-borders: var(--color-border-hi);
          --tw-prose-captions: var(--color-muted);
          --tw-prose-code: var(--color-fg);
          --tw-prose-pre-code: var(--color-fg);
          --tw-prose-pre-bg: var(--color-s1);
          --tw-prose-th-borders: var(--color-border-lo);
          --tw-prose-td-borders: var(--color-border-lo);
        "
      >
        <slot />
      </div>
    </article>
  </div>
</BaseLayout>
