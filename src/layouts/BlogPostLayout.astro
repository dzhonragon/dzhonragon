---
import BaseLayout from "./BaseLayout.astro";
import ShareButtons from "@/components/ShareButtons.astro";
import { site, t } from "@/data/site";
import type { Lang } from "@/data/site";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  lang: Lang;
  translationSlug?: string;
  github?: string;
}

const { title, description, pubDate, tags, lang, translationSlug, github } = Astro.props;
const trans = t(lang);
const otherLang = lang === "pt" ? "en" : "pt";
const htmlLang = lang === "pt" ? "pt-BR" : "en";

const switchPath = translationSlug
  ? `/${otherLang}/blog/${translationSlug}`
  : `/${otherLang}/blog`;

const canonicalURL = new URL(Astro.url.pathname, site.url).toString();

const locale = lang === "pt" ? "pt-BR" : "en-US";
const day = pubDate.getUTCDate().toString().padStart(2, "0");
const month = pubDate
  .toLocaleDateString(locale, { month: "short", timeZone: "UTC" })
  .toUpperCase()
  .replace(".", "");
const year = pubDate.getUTCFullYear();
const formattedDate = `${day} ${month} ${year}`;

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  url: canonicalURL,
  inLanguage: htmlLang,
  author: {
    "@type": "Person",
    "@id": `${site.url}/#person`,
    name: site.fullName,
    url: site.url,
  },
  publisher: {
    "@type": "Person",
    "@id": `${site.url}/#person`,
  },
  ...(tags.length > 0 && { keywords: tags.join(", ") }),
};
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  type="article"
  switchPath={switchPath}
  canonicalURL={canonicalURL}
>
  <!-- Article-specific head tags injected into BaseLayout's <slot name="head"> -->
  <Fragment slot="head">
    <!-- OG article tags -->
    <meta property="article:published_time" content={pubDate.toISOString()} />
    <meta property="article:author" content={site.fullName} />
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- BlogPosting structured data -->
    <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(blogPostingSchema)}</script>`} />
  </Fragment>

  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-10 sm:py-14">

    <div class="mb-10" style="border-bottom: 1px solid var(--color-border-lo); padding-bottom: 1rem;">
      <a
        href={`/${lang}/blog`}
        class="text-xs font-mono opacity-50 hover:opacity-100"
        style="color: var(--color-fg);"
      >
        {trans.postBack}
      </a>
    </div>

    <article>
      <header class="mb-10">
        <h1
          class="text-2xl sm:text-3xl font-bold leading-tight mb-5"
          style="color: var(--color-fg);"
        >
          {title}
        </h1>
        <div class="flex flex-wrap items-center gap-3">
          <time
            datetime={pubDate.toISOString()}
            class="font-mono text-xs"
            style="color: var(--color-muted);"
          >
            {formattedDate}
          </time>
          {tags.map((tag) => (
            <span
              class="font-mono text-xs px-1.5 py-0.5"
              style="color: var(--color-muted); border: 1px solid var(--color-border-lo);"
            >
              #{tag}
            </span>
          ))}
          {github && (
            <a
              href={github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 font-mono text-xs opacity-50 hover:opacity-100"
              style="color: var(--color-fg);"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
              {trans.actions.viewGithub}
            </a>
          )}
        </div>
      </header>

      <div
        class="prose prose-sm sm:prose-base max-w-none
               dark:prose-invert
               prose-headings:font-semibold
               prose-p:leading-relaxed
               prose-a:underline prose-a:underline-offset-2
               prose-code:font-mono prose-code:text-sm
               prose-pre:border
               prose-blockquote:not-italic"
        style="
          --tw-prose-body: var(--color-fg);
          --tw-prose-headings: var(--color-fg);
          --tw-prose-links: var(--color-fg);
          --tw-prose-bold: var(--color-fg);
          --tw-prose-counters: var(--color-muted);
          --tw-prose-bullets: var(--color-muted);
          --tw-prose-hr: var(--color-border-lo);
          --tw-prose-quotes: var(--color-fg);
          --tw-prose-quote-borders: var(--color-border-hi);
          --tw-prose-captions: var(--color-muted);
          --tw-prose-code: var(--color-fg);
          --tw-prose-pre-code: var(--color-fg);
          --tw-prose-pre-bg: var(--color-s1);
          --tw-prose-th-borders: var(--color-border-lo);
          --tw-prose-td-borders: var(--color-border-lo);
        "
      >
        <slot />
      </div>
    </article>

    <ShareButtons
      url={canonicalURL}
      title={title}
      shareLabel={trans.actions.share}
      copyLabel={trans.actions.copyLink}
      copiedLabel={trans.actions.copied}
    />
  </div>
</BaseLayout>
