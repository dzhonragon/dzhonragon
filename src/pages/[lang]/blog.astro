---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogPostPreview from "@/components/BlogPostPreview.astro";
import { t } from "@/data/site";
import { getLocalePaths, getLocalePosts } from "@/i18n/utils";
import type { Lang } from "@/data/site";

export function getStaticPaths() {
  return getLocalePaths();
}

const { lang } = Astro.params as { lang: Lang };
const trans = t(lang);
const posts = await getLocalePosts(lang);
---

<BaseLayout title={trans.blog.heading} lang={lang}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 sm:py-14">

    <header class="mb-10">
      <a
        href={`/${lang}`}
        class="inline-block font-mono text-xs opacity-40 hover:opacity-80 mb-8"
        style="color: var(--color-fg);"
      >
        {trans.back}
      </a>
      <a
        href={`/${lang}/blog`}
        class="block font-mono text-xs uppercase tracking-widest underline underline-offset-4 mb-3"
        style="color: var(--color-muted);"
      >
        {trans.blog.lead}
      </a>
      <h1 class="text-3xl sm:text-4xl font-bold" style="color: var(--color-fg);">
        {trans.blog.heading}
      </h1>
    </header>

    {
      posts.length === 0 ? (
        <p class="font-mono text-sm" style="color: var(--color-muted);">
          {trans.blog.empty}
        </p>
      ) : (
        <div
          class="grid sm:grid-cols-2 gap-px"
          style="background: var(--color-border-lo);"
        >
          {posts.map((post) => (
            <BlogPostPreview
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.slug}
              tags={post.data.tags}
              lang={lang}
            />
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
