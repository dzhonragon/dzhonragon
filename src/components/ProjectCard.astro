---
import { t } from "@/data/site";
import type { Lang } from "@/data/site";
import type { Project } from "@/data/projects";

interface Props extends Project {
  lang: Lang;
}

const { translations, tech, github, demo, image, lang } = Astro.props;
const trans = t(lang);
const { title, description } = translations[lang];
const id = `modal-${title.toLowerCase().replace(/[^a-z0-9]/g, "-")}-${Math.random().toString(36).slice(2, 6)}`;
---

<!-- Card -->
<button
  onclick={`document.getElementById('${id}').showModal()`}
  class="group w-full text-left h-full flex flex-col gap-3 p-5 sm:p-6"
  style="height:160px; overflow:hidden; background:var(--color-s1); border:1px solid var(--color-border-lo);"
>
  <!-- Meta row: GitHub icon (left) | #tech tags (right) -->
  <div class="flex items-start justify-between gap-3">
    <span class="opacity-40 group-hover:opacity-70 shrink-0" style="color:var(--color-fg);">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
      </svg>
    </span>
    <div class="flex flex-wrap gap-1 justify-end">
      {tech.slice(0, 2).map((tag) => (
        <span
          class="font-mono text-xs px-1.5 py-0.5"
          style="color:var(--color-muted); border:1px solid var(--color-border-lo);"
        >
          #{tag}
        </span>
      ))}
    </div>
  </div>

  <!-- Title (1 line) -->
  <h3
    class="font-semibold leading-snug text-base truncate group-hover:opacity-70"
    style="color:var(--color-fg);"
  >
    {title}
  </h3>

  <!-- Description (2 lines max, then "...") -->
  <p
    class="text-sm leading-relaxed line-clamp-2 flex-1"
    style="color:var(--color-muted);"
  >
    {description}
  </p>
</button>

<!-- Modal -->
<dialog
  id={id}
  class="w-[calc(100vw-2rem)] max-w-lg p-0"
  style="background:var(--color-bg); color:var(--color-fg); border:1px solid var(--color-border-hi);"
>
  <div class="flex flex-col">
    <!-- Header -->
    <div
      class="flex items-start justify-between gap-4 p-5 sm:p-6"
      style="border-bottom:1px solid var(--color-border-lo);"
    >
      <h2 class="font-mono font-semibold text-base" style="color:var(--color-fg);">
        {title}
      </h2>
      <button
        onclick={`document.getElementById('${id}').close()`}
        aria-label={trans.actions.close}
        class="opacity-40 hover:opacity-100 shrink-0 mt-0.5"
        style="color:var(--color-fg);"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Image (only in modal) -->
    {image && (
      <div style="border-bottom:1px solid var(--color-border-lo);">
        <img src={image} alt={title} class="w-full object-cover" style="aspect-ratio:16/9;" />
      </div>
    )}

    <!-- Body -->
    <div class="flex flex-col gap-5 p-5 sm:p-6">
      <p class="text-sm leading-relaxed" style="color:var(--color-muted);">
        {description}
      </p>

      <div class="flex flex-wrap gap-1.5">
        {tech.map((tag) => (
          <span
            class="font-mono text-xs px-1.5 py-0.5"
            style="color:var(--color-muted); border:1px solid var(--color-border-lo);"
          >
            #{tag}
          </span>
        ))}
      </div>

      <!-- Links: icon-only GitHub + optional demo -->
      <div class="flex justify-center gap-3 pt-1">
        <a
          href={github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="w-9 h-9 flex items-center justify-center opacity-70 hover:opacity-100"
          style="color:var(--color-fg); border:1px solid var(--color-border-hi);"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        {demo && (
          <a
            href={demo}
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-xs px-4 py-2.5 opacity-80 hover:opacity-100"
            style="background:var(--color-fg); color:var(--color-bg);"
          >
            demo ↗
          </a>
        )}
      </div>
    </div>
  </div>
</dialog>

<style>
  dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }
  dialog[open] {
    animation: modal-in 0.18s ease-out;
  }
  @keyframes modal-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  document.querySelectorAll("dialog").forEach((dialog) => {
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });
  });
</script>
