---
import { site } from "@/data/site";

const year = new Date().getFullYear();
---

<footer
  class="mt-auto"
  style="border-top: 1px solid var(--color-border-lo);"
>
  <div
    class="max-w-5xl mx-auto px-4 sm:px-6 py-5 flex items-center justify-between gap-4"
  >
    <p class="text-xs font-mono" style="color: var(--color-muted);">
      © {year} {site.name}
    </p>
    <p class="text-xs font-mono" style="color: var(--color-muted);">
      {site.fullName}
    </p>
  </div>
</footer>
